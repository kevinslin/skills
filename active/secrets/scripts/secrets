#!/usr/bin/env bash
set -euo pipefail

SECRETS_HOME="${SECRETS_HOME:-$HOME/.secrets}"

usage() {
  cat <<'USAGE'
Usage:
  secrets <name>[.<stage>] [-- command ...]
  secrets init <name>[.<stage>]
  secrets path <name>[.<stage>]

Examples:
  secrets slack -- slack-cli auth test
  secrets chat.prod -- ./scripts/check-chat
  secrets init foo
  secrets path chat.prod
USAGE
}

die() {
  printf 'secrets: %s\n' "$*" >&2
  exit 1
}

require_dotenvx() {
  command -v dotenvx >/dev/null 2>&1 || die "dotenvx is required. Install it with: npm install @dotenvx/dotenvx --global"
}

validate_target() {
  local target="$1"
  [[ -n "$target" ]] || die "missing secret set name"
  [[ "$target" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || die "invalid name '$target' (use letters, numbers, dot, underscore, or dash)"
  [[ "$target" != *".."* ]] || die "invalid name '$target' (empty dot segments are not allowed)"
}

secret_file() {
  local target="$1"
  validate_target "$target"
  printf '%s/.env.%s\n' "$SECRETS_HOME" "$target"
}

ensure_home() {
  mkdir -p "$SECRETS_HOME"
  chmod 700 "$SECRETS_HOME"
}

init_target() {
  local target="$1"
  local file
  file="$(secret_file "$target")"
  ensure_home
  if [[ -e "$file" ]]; then
    chmod 600 "$file"
    printf 'exists: %s\n' "$file"
  else
    umask 077
    : > "$file"
    chmod 600 "$file"
    printf 'created: %s\n' "$file"
  fi
}

run_target() {
  local target="$1"
  shift
  local file
  file="$(secret_file "$target")"
  [[ -f "$file" ]] || die "missing $file (create it with: secrets init $target)"
  require_dotenvx

  if [[ "${1:-}" == "--" ]]; then
    shift
  fi

  if [[ "$#" -gt 0 ]]; then
    exec dotenvx run --no-ops -f "$file" -- "$@"
  fi

  if [[ -t 0 && -t 1 ]]; then
    exec dotenvx run --no-ops -f "$file" -- "${SHELL:-/bin/sh}" -i
  fi

  printf 'env file: %s\n' "$file"
  printf 'run command: dotenvx run --no-ops -f %q -- <command>\n' "$file"
}

main() {
  if [[ "$#" -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
  fi

  case "$1" in
    init)
      shift
      [[ "$#" -eq 1 ]] || die "usage: secrets init <name>[.<stage>]"
      init_target "$1"
      ;;
    path)
      shift
      [[ "$#" -eq 1 ]] || die "usage: secrets path <name>[.<stage>]"
      secret_file "$1"
      ;;
    *)
      local target="$1"
      shift
      run_target "$target" "$@"
      ;;
  esac
}

main "$@"
